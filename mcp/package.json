{
  "name": "grasp-mcp-server",
  "version": "2.6.0",
  "description": "MCP server for Grasp — codebase dependency analysis, architecture intelligence, live watch, git timeline, duplicate detection, and refactor tooling for LLMs and agents",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "grasp-mcp": "dist/index.js",
    "grasp": "dist/cli.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepare": "node build.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@octokit/rest": "^21.0.2",
    "acorn": "^8.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./dist/analyzer.js": "./dist/analyzer.js",
    "./dist/parser.js": "./dist/parser.js"
  },
  "keywords": [
    "mcp",
    "grasp",
    "code-analysis",
    "dependency-graph",
    "architecture",
    "llm",
    "agents",
    "cli",
    "refactor",
    "duplicate-detection",
    "monorepo",
    "git-timeline",
    "live-watch",
    "health-score"
  ],
  "license": "MIT",
  "mcpName": "io.github.ashfordeOU/grasp"
}
