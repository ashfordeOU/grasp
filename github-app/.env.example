# GitHub App credentials — set these in your deployment environment
# Never commit the real values

# App ID from GitHub App settings page
GITHUB_APP_ID=123456

# Private key (PEM format, base64-encoded) — download from GitHub App settings
# Encode with: base64 -w0 private-key.pem
GITHUB_PRIVATE_KEY_BASE64=

# Webhook secret — set in GitHub App settings → Webhook secret
GITHUB_WEBHOOK_SECRET=your-secret-here

# Port for the HTTP server (default 3000)
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: override the Grasp UI base URL used in PR comments
GRASP_UI_URL=https://ashforde.github.io/grasp/
