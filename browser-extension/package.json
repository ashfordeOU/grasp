{
  "name": "grasp-browser-extension",
  "version": "3.1.1",
  "private": true,
  "description": "Chrome/Firefox extension for Grasp code architecture",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:firefox": "web-ext build --source-dir . --artifacts-dir dist/firefox --ignore-files 'dist/**' 'node_modules/**' 'webpack.config.js' 'tsconfig.json' '*.ts'",
    "test": "jest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/jest": "^29",
    "@types/node": "^20",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5",
    "webpack": "^5",
    "webpack-cli": "^5",
    "ts-loader": "^9"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
