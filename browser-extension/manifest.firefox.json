{
  "manifest_version": 2,
  "name": "Grasp \u2014 Code Architecture",
  "version": "3.3.18",
  "description": "Dependency graph, health score, and security scanner for GitHub and GitLab repos",
  "browser_specific_settings": {
    "gecko": {
      "id": "grasp@ashforde.org",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "*://github.com/*",
    "*://gitlab.com/*"
  ],
  "optional_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*/*",
        "*://gitlab.com/*/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": [
      "dist/background.js"
    ],
    "persistent": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grasp Architecture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}