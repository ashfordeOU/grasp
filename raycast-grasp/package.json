{
  "name": "grasp",
  "title": "Grasp — Code Architecture",
  "description": "Analyse any GitHub repo — get health score, dependency graph, security issues",
  "icon": "icon.png",
  "author": "ashfordeou",
  "license": "Elastic-2.0",
  "version": "3.6.0",
  "private": true,
  "commands": [
    {
      "name": "analyze-repo",
      "title": "Analyze Repository",
      "description": "Analyse a repository with Grasp and view health score",
      "mode": "view"
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "test": "jest"
  },
  "dependencies": {},
  "devDependencies": {
    "@raycast/api": "^1.0.0",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^18",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "@raycast/api": "<rootDir>/__mocks__/raycast-api.ts"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    }
  }
}
