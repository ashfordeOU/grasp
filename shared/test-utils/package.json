{
  "name": "@grasp/test-utils",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^29",
    "babel-jest": "^30.3.0",
    "jest": "^29",
    "msw": "^2.13.4",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": { "resolveJsonModule": true, "esModuleInterop": true } }],
      "^.+\\.m?js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(msw|@mswjs|rettime|until-async|outvariant|strict-event-emitter|@open-draft|headers-polyfill|set-cookie-parser|tough-cookie|tagged-tag|baseline-browser-mapping|get-package-type)/)"
    ]
  }
}
